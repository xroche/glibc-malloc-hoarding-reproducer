diff --git a/malloc/malloc.c b/malloc/malloc.c
index 6455a1b0e0..e5a9929f36 100644
--- a/malloc/malloc.c
+++ b/malloc/malloc.c
@@ -1029,7 +1029,7 @@ static void _int_free_merge_chunk (mstate, mchunkptr, INTERNAL_SIZE_T);
 static INTERNAL_SIZE_T _int_free_create_chunk (mstate,
 					       mchunkptr, INTERNAL_SIZE_T,
 					       mchunkptr, INTERNAL_SIZE_T);
-static void _int_free_maybe_trim (mstate, INTERNAL_SIZE_T);
+static void _int_free_maybe_trim (mstate, mchunkptr, INTERNAL_SIZE_T);
 static void*  _int_realloc(mstate, mchunkptr, INTERNAL_SIZE_T,
 			   INTERNAL_SIZE_T);
 static void*  _int_memalign(mstate, size_t, size_t);
@@ -4352,7 +4352,7 @@ _int_free_merge_chunk (mstate av, mchunkptr p, INTERNAL_SIZE_T size)
 
   /* Write the chunk header, maybe after merging with the following chunk.  */
   size = _int_free_create_chunk (av, p, size, nextchunk, nextsize);
-  _int_free_maybe_trim (av, size);
+  _int_free_maybe_trim (av, p, size);
 }
 
 /* Create a chunk at P of SIZE bytes, with SIZE potentially increased
@@ -4434,12 +4434,25 @@ _int_free_create_chunk (mstate av, mchunkptr p, INTERNAL_SIZE_T size,
 /* If the total unused topmost memory exceeds trim threshold, ask malloc_trim
    to reduce top.  */
 static void
-_int_free_maybe_trim (mstate av, INTERNAL_SIZE_T size)
+_int_free_maybe_trim (mstate av, mchunkptr p, INTERNAL_SIZE_T size)
 {
   /* We don't want to trim on each free.  As a compromise, trimming is attempted
      if ATTEMPT_TRIMMING_THRESHOLD is reached.  */
   if (size >= ATTEMPT_TRIMMING_THRESHOLD)
     {
+      /* Release physical pages from the interior of this free chunk.
+	 Before glibc 2.26 (tcache), fastbin consolidation produced free
+	 regions large enough for systrim/heap_trim to return memory.
+	 tcache bypasses consolidation, so interior chunks now retain
+	 their pages indefinitely.  This madvise restores the pre-tcache
+	 memory-return behavior.  */
+      size_t ps = GLRO (dl_pagesize);
+      char *paligned = PTR_ALIGN_UP ((char *) p
+				     + sizeof (struct malloc_chunk), ps);
+      char *pend = PTR_ALIGN_DOWN ((char *) p + size, ps);
+      if (pend > paligned)
+	__madvise (paligned, pend - paligned, MADV_DONTNEED);
+
       if (av == &main_arena)
 	{
 #ifndef MORECORE_CANNOT_TRIM
@@ -4648,7 +4661,7 @@ _int_memalign (mstate av, size_t alignment, size_t bytes)
       set_head_size (p, nb);
       size = _int_free_create_chunk (av, remainder, size - nb, nextchunk,
 				     chunksize (nextchunk));
-      _int_free_maybe_trim (av, size);
+      _int_free_maybe_trim (av, remainder, size);
     }
 
   check_inuse_chunk (av, p);
