+      /* If madvise_threshold is set and the consolidated chunk is
+	 large enough, release its page-aligned interior back to the
+	 kernel via MADV_DONTNEED.  Without this, interior free chunks
+	 retain their physical pages indefinitely because top-chunk
+	 trimming only operates on the heap boundary.  */
+      if (__glibc_unlikely (mp_.madvise_threshold > 0)
+	  && size >= mp_.madvise_threshold)
+	{
+	  size_t ps = GLRO (dl_pagesize);
+
+	  /* Skip past the chunk header (sizeof(struct malloc_chunk) = 48
+	     bytes on 64-bit) to preserve the bin list pointers (fd, bk,
+	     fd_nextsize, bk_nextsize), then round up to a page boundary.  */
+	  char *paligned_mem = PTR_ALIGN_UP ((char *) p
+					     + sizeof (struct malloc_chunk),
+					     ps);
+	  char *pend = PTR_ALIGN_DOWN ((char *) p + size, ps);
+
+	  if (pend > paligned_mem)
+	    __madvise (paligned_mem, pend - paligned_mem, MADV_DONTNEED);
+	}
