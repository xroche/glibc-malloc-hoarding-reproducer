-_int_free_maybe_trim (mstate av, INTERNAL_SIZE_T size)
+_int_free_maybe_trim (mstate av, mchunkptr p,
+		      INTERNAL_SIZE_T orig_size, INTERNAL_SIZE_T size)
 {
+  /* Track cumulative bytes freed (before consolidation) in this arena.
+     When the accumulator crosses MADVISE_PURGE_THRESHOLD and the
+     consolidated chunk is large enough, call madvise(MADV_DONTNEED)
+     on its page-aligned interior.
+
+     Before glibc 2.26 (tcache), fastbin consolidation produced regions
+     large enough for systrim/heap_trim to return memory.  tcache
+     bypasses consolidation, so interior chunks now retain their pages
+     indefinitely.  The accumulator batches madvise calls so that
+     freeing many small adjacent blocks doesn't cause a syscall per
+     free.  We accumulate orig_size (the size before consolidation)
+     rather than the consolidated size, so that a million 100-byte
+     frees accumulate at 100 bytes each, not at the growing merged
+     size.  */
+  av->madvise_accumulator += orig_size;
+
